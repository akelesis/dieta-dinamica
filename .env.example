# Chave secreta usada apenas pelo servidor. Nunca use o prefixo VITE_ aqui.
OPENAI_API_KEY=cole-sua-chave-aqui

# Modelo usado para interpretar refeições em linguagem natural.
OPENAI_MODEL=gpt-5.6

# Modelo de menor latência usado para montar o dia alimentar completo.
OPENAI_PLAN_MODEL=gpt-5.4-mini

# Porta interna da API local.
API_PORT=8787

# Opcional: caminho do SQLite usado para reaproveitar estimativas anteriores.
FOOD_CACHE_DB=./data/vivameta.sqlite

# Ao preencher estas duas variáveis, o app usa Auth, banco e Edge Functions do Supabase.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua-chave
VITE_BASIC_PLAN_PRICE_LABEL=R$ 19,90/mês
VITE_GUIDED_PLAN_PRICE_LABEL=R$ 39,90/mês
